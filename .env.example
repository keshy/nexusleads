# Docker Compose Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32

# =============================================================================
# GitHub API
# =============================================================================
# Required for repository and contributor data
# Get token from: https://github.com/settings/tokens
# Scopes needed: public_repo, read:user
GITHUB_TOKEN=ghp_your_github_personal_access_token

# =============================================================================
# Discord API (Optional - for scanning Discord server members)
# =============================================================================
# Create a bot at: https://discord.com/developers/applications
# Enable SERVER MEMBERS INTENT and MESSAGE CONTENT INTENT
DISCORD_BOT_TOKEN=

# =============================================================================
# Reddit API (Optional - for scanning subreddit participants)
# =============================================================================
# Create a 'script' app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# =============================================================================
# X / Twitter API (Optional - for scanning followers and engagers)
# =============================================================================
# Create a project at: https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=

# =============================================================================
# StockTwits API (Optional - for scanning ticker stream participants)
# =============================================================================
# Get token at: https://stocktwits.com/developers
STOCKTWITS_TOKEN=

# =============================================================================
# Azure OpenAI API (Optional - for AI-powered lead classification)
# =============================================================================
# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =============================================================================
# Serper API (Optional - for LinkedIn and web search)
# =============================================================================
# Get API key from: https://serper.dev/
# Free tier: 2,500 searches/month
SERPER_API_KEY=your-serper-api-key-here

# =============================================================================
# Job Processor Configuration
# =============================================================================
CHECK_INTERVAL_SECONDS=30
MAX_CONCURRENT_JOBS=3

# =============================================================================
# Database Configuration (Docker Compose defaults)
# =============================================================================
# Note: These match docker-compose.yml defaults
# Only change if you modify docker-compose.yml
POSTGRES_DB=plg_lead_sourcer
POSTGRES_USER=plg_user
POSTGRES_PASSWORD=plg_password
# Host port used for Postgres access from host-run assistant (prod/local)
POSTGRES_PORT=5433

# =============================================================================
# Application URLs
# =============================================================================
# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
# Production frontend URL (if different)
# FRONTEND_URL=https://your-domain.com

# =============================================================================
# Codex Assistant (Chat)
# =============================================================================
# Frontend WebSocket endpoint for chat assistant
VITE_CODEX_WS_URL=ws://localhost:3001/ws/codex

# Host assistant service port
ASSISTANT_PORT=3001

# Recommended local setup on macOS:
# run assistant on host with `make assistant-local`
DATABASE_URL=postgresql://plg_user:plg_password@localhost:5433/plg_lead_sourcer
PROJECT_ROOT=.

# =============================================================================
# Feature Flags
# =============================================================================
# Set to "true" to enable billing UI (credit balance, purchase, auto-reload)
VITE_FEATURE_BILLING=false

# Optional: if not using ~/.codex/auth.json, provide API key explicitly
OPENAI_API_KEY=
